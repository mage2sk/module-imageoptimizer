{
  "name": "mage2kishan/module-imageoptimizer",
  "description": "Frontend image performance: lazy loading (Native/IntersectionObserver/Hybrid), WebP browser detection with fallback, preload hints, async decoding, and fetchpriority",
  "type": "magento2-module",
  "version": "1.0.0",
  "license": "proprietary",
  "authors": [
    {
      "name": "Kishan Savaliya",
      "email": "kishansavaliyakb@gmail.com"
    }
  ],
  "require": {
    "php": ">=8.1",
    "magento/framework": "^103.0",
    "magento/module-store": "^101.0",
    "magento/module-catalog": "^103.0 || ^104.0",
    "mage2kishan/module-core": "^1.0",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.5 || ^10.0",
    "squizlabs/php_codesniffer": "^3.7"
  },
  "autoload": {
    "psr-4": {
      "Panth\\ImageOptimizer\\": ""
    },
    "files": [
      "registration.php"
    ]
  },
  "keywords": [
    "magento2",
    "hyva",
    "lazy-loading",
    "image-optimization",
    "webp-detection",
    "core-web-vitals"
  ],
  "minimum-stability": "stable"
}
